{"file":"services-C4KEay63.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;AAIA,UAAM,QAAQ;AAUd,UAAM,WAAW;AAAA,MACf,EAAE,OAAO,UAAU,OAAO,gBAAA;AAAA,MAC1B,EAAE,OAAO,aAAa,OAAO,yBAAA;AAAA,MAC7B,EAAE,OAAO,OAAO,OAAO,aAAA;AAAA,MACvB,EAAE,OAAO,UAAU,OAAO,SAAA;AAAA,MAC1B,EAAE,OAAO,QAAQ,OAAO,iBAAA;AAAA,IAAiB;AAG3C,UAAM,cAAc,OAAO;AAAA,MACzB,MAAM;AAAA,MACN,KAAK;AAAA,MACL,QAAQ;AAAA,MACR,SAAS;AAAA,MACT,SAAS,CAAA;AAAA,MACT,MAAM;AAAA,MACN,OAAO;AAAA,MACP,cAAc;AAAA,MACd,SAAS;AAAA,IAAA;AAGX,UAAM,OAAO,SAAS,aAAa;AAEnC;AAAA,MACE,MAAM,MAAM;AAAA,MACZ,CAAC,SAAS;AACR,YAAI,MAAM;AACR,cAAI,MAAM,SAAS;AACjB,iBAAK,OAAO,MAAM,QAAQ;AAC1B,iBAAK,MAAM,MAAM,QAAQ;AACzB,iBAAK,SAAS,MAAM,QAAQ;AAC5B,iBAAK,UAAU,MAAM,QAAQ;AAC7B,iBAAK,UAAU,OAAO,QAAQ,MAAM,QAAQ,OAAO,EAAE,IAAI,CAAC,CAAC,KAAK,KAAK,OAAO,EAAE,KAAK,QAAQ;AAC3F,iBAAK,OAAO,MAAM,QAAQ,QAAQ;AAClC,iBAAK,QAAQ,MAAM,QAAQ,SAAS;AACpC,iBAAK,eAAe,MAAM,QAAQ;AAClC,iBAAK,UAAU,MAAM,QAAQ;AAAA,UAC/B,OACK;AACH,mBAAO,OAAO,MAAM,aAAa;AAAA,UACnC;AAAA,QACF;AAAA,MACF;AAAA,IAAA;;+BAiDA,CAyMWA,WAAA;YA/LC,QAAA,MAAI;;cAWA,QAAA,MAAI;uQAMH,QAAA,UAAO,wBAAA,oBAAA,CAAA,0WAAA;iBAeA,QAAA,SAAO;;AAIIC,4BAAAC,MAAA,eAAA,IAAV,WAAM;AAKVF,uBAAA,kIAAAG,eAAA,OAAO,IAAI,CAAA,WAAA;AAAA;;;;;6IAWPC,cAAA,SAAAF,MAAA,IAAA,EAAK,IAAI,6dAcPG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,MAAM,IAAXI,gBAAAJ,MAAA,IAAA,EAAK,QAAM,KAAA,IAAXK,cAAAL,MAAA,IAAA,EAAK,QAAM,KAAA,CAAA,IAAA,cAAA,sCAAXG,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,MAAM,IAAXI,gBAAAJ,MAAA,IAAA,EAAK,QAAM,MAAA,IAAXK,cAAAL,MAAA,IAAA,EAAK,QAAM,MAAA,CAAA,IAAA,cAAA,kCAOXE,cAAA,SAAAF,MAAA,IAAA,EAAK,GAAG;AAeCD,0BAAA,WAAL,MAAC;6CAA8B,SAAO,EAAE,KAAK,IAHnDI,sBAAA,MAAA,QAAAH,MAAA,IAAA,EAAK,OAAO,IAAZI,gBAAAJ,MAAA,IAAA,EAAK,SAGuC,EAAE,KAAK,IAHnDK,cAAAL,MAAA,IAAA,EAAK,SAGuC,EAAE,KAAK,CAAA,IAAA,cAAA,MAAKC,eAAA,EAAE,KAAK;;;gBAe/DD,MAAA,IAAA,EAAK,QAAQ,SAAM,GAAA;;AAEJD,4BAAAC,MAAA,IAAA,EAAK,SAAO,CAA1B,QAAQ,MAAC;qEAKNE,cAAA,SAAA,OAAO,GAAG,gKAMVA,cAAA,SAAA,OAAO,KAAK;;;;;;;AAkBlB,gBAAAF,MAAA,IAAA,EAAK,WAAM,QAAA;AAGTF,qBAAA,2SAAAG,eAAAD,MAAA,IAAA,EAAK,IAAI,CAAA,mBAAA;AAAA;;;yJAcAE,cAAA,SAAAF,MAAA,IAAA,EAAK,YAAY,iTAWxBE,cAAA,SAAAF,MAAA,IAAA,EAAK,KAAK,wgBAmBXA,MAAA,IAAA,EAAK,KAAK,WAAWA,MAAA,IAAA,EAAK,IAAI,MAAI,IAAA,cAAA,qBAG3C,QAAA,UAAO,gBAAA,SAAA;;;;;;;;;;;;;;;;;;;;;;ACrS1B,YAAQ,EAAE,OAAO,mCAAmC;AAEpD,UAAM,EAAE,UAAU,YAAY,cAA4C,IAAI,YAAA;AAC9E,UAAM,EAAE,cAA4B,IAAI,eAAA;AAExC,UAAM,WAAW,IAAI,KAAK;AAC1B,UAAM,iBAAiB,IAA0B,IAAI;AACrD,UAAM,gBAAgB,IAAmB,IAAI;AAY7C,aAAS,OAAO,QAAiD;AAC/D,UAAI,eAAe,OAAO;AACxB,sBAAc,eAAe,MAAM,IAAI,MAAM;AAAA,MAC/C,OACK;AACH,mBAAW,MAAM;AAAA,MACnB;AACA,eAAS,QAAQ;AAAA,IACnB;AAYA,UAAM,iBAAyC;AAAA,MAC7C,QAAQ;AAAA,MACR,WAAW;AAAA,MACX,QAAQ;AAAA,MACR,KAAK;AAAA,MACL,MAAM;AAAA,IAAA;;;;;;;QAWI,IAAG;AAAA,QACH,OAAM;AAAA,MAAA;yBAFR,CAOW,GAAAF,QAAAQ,UAAA,aAAA;;;;;4BAHTC,YAEM,OAAA;AAAA,gBAFD,OAAM;AAAA,gBAAU,MAAK;AAAA,gBAAO,QAAO;AAAA,gBAAe,SAAQ;AAAA,cAAA;gBAC7DC,YAA4F,QAAA;AAAA,kBAAtF,kBAAe;AAAA,kBAAQ,mBAAgB;AAAA,kBAAQ,gBAAa;AAAA,kBAAI,GAAE;AAAA,gBAAA;;;;;;;;AAoBrE,UAAAR,MAAA,QAAA,EAAS,WAAM,GAAA;;;;AAmBRD,sBAAAC,MAAA,QAAA,IAAP,QAAG;+BAGeS,eAAA,CAAA,EAAA,cAAA,CAAA,IAAI,WAAO,kFAAA,CAAA,qBAK1BA,eAAA,CAAA,IAAI,UAAO,iBAAA,eAAA,uJAAA,CAAA,mBAClB,SAAO,IAAI,UAAO,eAAA,SAAA,kBAKTA,eAAA,CAAA,IAAI,UAAO,kBAAA,mBAAA,kFAAA,CAAA,wIAOiCR,eAAA,IAAI,IAAI;cAEpDD,MAAA,aAAA,EAAc,IAAI,EAAE,GAAA;;cACzB,OAAOA,MAAA,aAAA,EAAc,IAAI,EAAE,EAAE;AAAA,cAC9B,MAAK;AAAA,YAAA;;;;AAGC,cAAA,IAAI,OAAK;AAGZ,kBAAA,4EAAAC,eAAA,IAAI,KAAK,CAAA,SAAA;AAAA;;;yHAIqBA,eAAA,IAAI,GAAG,kCAChBA,eAAA,eAAe,IAAI,OAAO,KAAK,IAAI,OAAO,kCAC1CA,eAAA,IAAI,YAAY;cAiBpCD,MAAA,aAAA,MAAkB,IAAI,IAAE;;;;;;;;;;;QAwBrB,OAAM;AAAA,QAAc,MAAK;AAAA,MAAA;;QACzB,OAAM;AAAA,QAAQ,MAAK;AAAA,MAAA;;QACnB,OAAM;AAAA,QAAS,MAAK;AAAA,MAAA;;QACpB,OAAM;AAAA,QAAS,MAAK;AAAA,MAAA;;QACpB,OAAM;AAAA,QAAc,MAAK;AAAA,MAAA;;;QAOzC,MAAMA,MAAA,QAAA;AAAA,QACN,SAASA,MAAA,cAAA;AAAA,QACT,qBAAO,SAAA,QAAQ;AAAA,QACf;AAAA,MAAA;;;;;;;;;;;","names":["_push","_ssrRenderList","_unref","_ssrInterpolate","_ssrRenderAttr","_ssrIncludeBooleanAttr","_ssrLooseContain","_ssrLooseEqual","_parent","_createBlock","_createVNode","_ssrRenderClass"],"sources":["../../../../components/ServiceForm.vue","../../../../pages/services.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { ServiceConfig } from '~/types'\nimport { PRESET_SERVICES } from '~/adapters/index'\n\nconst props = defineProps<{\n  open: boolean\n  editing?: ServiceConfig | null\n}>()\n\nconst emit = defineEmits<{\n  (e: 'close'): void\n  (e: 'save', config: Omit<ServiceConfig, 'id' | 'createdAt'>): void\n}>()\n\nconst ADAPTERS = [\n  { value: 'github', label: 'GitHub Status' },\n  { value: 'atlassian', label: 'Atlassian / Statuspage' },\n  { value: 'aws', label: 'AWS Health' },\n  { value: 'notion', label: 'Notion' },\n  { value: 'auto', label: 'Auto-détection' },\n]\n\nconst defaultForm = () => ({\n  name: '',\n  url: '',\n  method: 'GET' as const,\n  adapter: 'auto',\n  headers: [] as { key: string; value: string }[],\n  body: '',\n  group: '',\n  pollInterval: 60,\n  enabled: true,\n})\n\nconst form = reactive(defaultForm())\n\nwatch(\n  () => props.open,\n  (open) => {\n    if (open) {\n      if (props.editing) {\n        form.name = props.editing.name\n        form.url = props.editing.url\n        form.method = props.editing.method\n        form.adapter = props.editing.adapter\n        form.headers = Object.entries(props.editing.headers).map(([key, value]) => ({ key, value }))\n        form.body = props.editing.body ?? ''\n        form.group = props.editing.group ?? ''\n        form.pollInterval = props.editing.pollInterval\n        form.enabled = props.editing.enabled\n      }\n      else {\n        Object.assign(form, defaultForm())\n      }\n    }\n  },\n)\n\nfunction applyPreset(preset: (typeof PRESET_SERVICES)[number]) {\n  form.name = preset.name\n  form.url = preset.url\n  form.method = preset.method\n  form.adapter = preset.adapter\n  form.headers = []\n}\n\nfunction addHeader() {\n  form.headers.push({ key: '', value: '' })\n}\n\nfunction removeHeader(i: number) {\n  form.headers.splice(i, 1)\n}\n\nfunction submit() {\n  if (!form.name.trim() || !form.url.trim()) return\n\n  const headers: Record<string, string> = {}\n  for (const h of form.headers) {\n    if (h.key.trim()) headers[h.key.trim()] = h.value\n  }\n\n  emit('save', {\n    name: form.name.trim(),\n    url: form.url.trim(),\n    method: form.method,\n    adapter: form.adapter,\n    headers,\n    body: form.body || undefined,\n    group: form.group || undefined,\n    pollInterval: Math.min(Math.max(form.pollInterval, 10), 120),\n    enabled: form.enabled,\n  })\n}\n\nfunction onKeydown(e: KeyboardEvent) {\n  if (e.key === 'Escape') emit('close')\n}\n\nonMounted(() => document.addEventListener('keydown', onKeydown))\nonUnmounted(() => document.removeEventListener('keydown', onKeydown))\n</script>\n\n<template>\n  <Teleport to=\"body\">\n    <Transition\n      enter-active-class=\"transition duration-200\"\n      enter-from-class=\"opacity-0\"\n      enter-to-class=\"opacity-100\"\n      leave-active-class=\"transition duration-150\"\n      leave-from-class=\"opacity-100\"\n      leave-to-class=\"opacity-0\"\n    >\n      <div\n        v-if=\"open\"\n        class=\"fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4\"\n      >\n        <div class=\"absolute inset-0 bg-black/40 backdrop-blur-sm\" @click=\"emit('close')\" />\n\n        <Transition\n          enter-active-class=\"transition duration-200\"\n          enter-from-class=\"opacity-0 translate-y-4 sm:scale-95\"\n          enter-to-class=\"opacity-100 translate-y-0 sm:scale-100\"\n        >\n          <div\n            v-if=\"open\"\n            class=\"relative w-full max-w-xl max-h-[90vh] bg-white rounded-2xl shadow-xl flex flex-col\"\n          >\n            <!-- Header -->\n            <div class=\"flex items-center justify-between px-6 py-4 border-b border-gray-100\">\n              <h2 class=\"font-semibold text-gray-900 text-lg\">\n                {{ editing ? 'Modifier le service' : 'Ajouter un service' }}\n              </h2>\n              <button\n                class=\"p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n                @click=\"emit('close')\"\n              >\n                <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\n                </svg>\n              </button>\n            </div>\n\n            <!-- Form -->\n            <div class=\"flex-1 overflow-y-auto px-6 py-5 space-y-5\">\n              <!-- Presets -->\n              <div v-if=\"!editing\">\n                <p class=\"text-xs font-medium text-gray-500 uppercase tracking-wider mb-2\">Préconfigurations</p>\n                <div class=\"flex flex-wrap gap-2\">\n                  <button\n                    v-for=\"preset in PRESET_SERVICES\"\n                    :key=\"preset.name\"\n                    class=\"px-3 py-1.5 text-sm rounded-lg border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-colors\"\n                    @click=\"applyPreset(preset)\"\n                  >\n                    {{ preset.name }}\n                  </button>\n                </div>\n              </div>\n\n              <!-- Nom -->\n              <div>\n                <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                  Nom <span class=\"text-red-500\">*</span>\n                </label>\n                <input\n                  v-model=\"form.name\"\n                  type=\"text\"\n                  placeholder=\"ex: GitHub\"\n                  class=\"w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                />\n              </div>\n\n              <!-- URL + Méthode -->\n              <div>\n                <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                  URL <span class=\"text-red-500\">*</span>\n                </label>\n                <div class=\"flex gap-2\">\n                  <select\n                    v-model=\"form.method\"\n                    class=\"rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white\"\n                  >\n                    <option value=\"GET\">GET</option>\n                    <option value=\"POST\">POST</option>\n                  </select>\n                  <input\n                    v-model=\"form.url\"\n                    type=\"url\"\n                    placeholder=\"https://api.example.com/status\"\n                    class=\"flex-1 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                  />\n                </div>\n              </div>\n\n              <!-- Adapter -->\n              <div>\n                <label class=\"block text-sm font-medium text-gray-700 mb-1\">Adaptateur</label>\n                <select\n                  v-model=\"form.adapter\"\n                  class=\"w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white\"\n                >\n                  <option v-for=\"a in ADAPTERS\" :key=\"a.value\" :value=\"a.value\">{{ a.label }}</option>\n                </select>\n              </div>\n\n              <!-- Headers -->\n              <div>\n                <div class=\"flex items-center justify-between mb-2\">\n                  <label class=\"text-sm font-medium text-gray-700\">En-têtes HTTP</label>\n                  <button\n                    class=\"text-xs text-blue-600 hover:text-blue-700 font-medium\"\n                    @click=\"addHeader\"\n                  >\n                    + Ajouter\n                  </button>\n                </div>\n                <div v-if=\"form.headers.length > 0\" class=\"space-y-2\">\n                  <div\n                    v-for=\"(header, i) in form.headers\"\n                    :key=\"i\"\n                    class=\"flex gap-2 items-center\"\n                  >\n                    <input\n                      v-model=\"header.key\"\n                      type=\"text\"\n                      placeholder=\"Clé\"\n                      class=\"flex-1 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                    />\n                    <input\n                      v-model=\"header.value\"\n                      type=\"text\"\n                      placeholder=\"Valeur\"\n                      class=\"flex-1 rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                    />\n                    <button\n                      class=\"p-2 text-gray-400 hover:text-red-500 transition-colors\"\n                      @click=\"removeHeader(i)\"\n                    >\n                      <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\n                      </svg>\n                    </button>\n                  </div>\n                </div>\n              </div>\n\n              <!-- Body (POST) -->\n              <div v-if=\"form.method === 'POST'\">\n                <label class=\"block text-sm font-medium text-gray-700 mb-1\">Corps (JSON)</label>\n                <textarea\n                  v-model=\"form.body\"\n                  rows=\"3\"\n                  placeholder='{\"key\": \"value\"}'\n                  class=\"w-full rounded-lg border border-gray-200 px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none\"\n                />\n              </div>\n\n              <!-- Intervalle + Groupe -->\n              <div class=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700 mb-1\">\n                    Intervalle (s)\n                  </label>\n                  <input\n                    v-model.number=\"form.pollInterval\"\n                    type=\"number\"\n                    min=\"10\"\n                    max=\"120\"\n                    class=\"w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                  />\n                  <p class=\"text-xs text-gray-400 mt-1\">10–120 secondes</p>\n                </div>\n                <div>\n                  <label class=\"block text-sm font-medium text-gray-700 mb-1\">Groupe</label>\n                  <input\n                    v-model=\"form.group\"\n                    type=\"text\"\n                    placeholder=\"ex: Infrastructure\"\n                    class=\"w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                  />\n                </div>\n              </div>\n            </div>\n\n            <!-- Footer -->\n            <div class=\"px-6 py-4 border-t border-gray-100 flex justify-end gap-3\">\n              <button\n                class=\"px-4 py-2 text-sm text-gray-600 hover:text-gray-800 transition-colors\"\n                @click=\"emit('close')\"\n              >\n                Annuler\n              </button>\n              <button\n                class=\"px-4 py-2 text-sm font-medium bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors disabled:opacity-50\"\n                :disabled=\"!form.name.trim() || !form.url.trim()\"\n                @click=\"submit\"\n              >\n                {{ editing ? 'Enregistrer' : 'Ajouter' }}\n              </button>\n            </div>\n          </div>\n        </Transition>\n      </div>\n    </Transition>\n  </Teleport>\n</template>\n","<script setup lang=\"ts\">\nimport type { ServiceConfig } from '~/types'\nimport { useServices } from '~/composables/useServices'\nimport { useStatusStore } from '~/composables/useStatusStore'\n\nuseHead({ title: 'Services — Status Concentrateur' })\n\nconst { services, addService, updateService, removeService, toggleService } = useServices()\nconst { currentStatus, clearHistory } = useStatusStore()\n\nconst formOpen = ref(false)\nconst editingService = ref<ServiceConfig | null>(null)\nconst deleteConfirm = ref<string | null>(null)\n\nfunction openAdd() {\n  editingService.value = null\n  formOpen.value = true\n}\n\nfunction openEdit(svc: ServiceConfig) {\n  editingService.value = svc\n  formOpen.value = true\n}\n\nfunction onSave(config: Omit<ServiceConfig, 'id' | 'createdAt'>) {\n  if (editingService.value) {\n    updateService(editingService.value.id, config)\n  }\n  else {\n    addService(config)\n  }\n  formOpen.value = false\n}\n\nfunction confirmDelete(id: string) {\n  deleteConfirm.value = id\n}\n\nfunction doDelete(id: string) {\n  removeService(id)\n  clearHistory(id)\n  deleteConfirm.value = null\n}\n\nconst ADAPTER_LABELS: Record<string, string> = {\n  github: 'GitHub Status',\n  atlassian: 'Atlassian',\n  notion: 'Notion',\n  aws: 'AWS',\n  auto: 'Auto',\n}\n</script>\n\n<template>\n  <div>\n    <!-- Nav -->\n    <nav class=\"bg-white border-b border-gray-100 sticky top-0 z-40\">\n      <div class=\"max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between\">\n        <div class=\"flex items-center gap-3\">\n          <NuxtLink\n            to=\"/\"\n            class=\"p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n          >\n            <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\" />\n            </svg>\n          </NuxtLink>\n          <span class=\"font-semibold text-gray-900\">Gestion des services</span>\n        </div>\n\n        <button\n          class=\"flex items-center gap-1.5 px-3 py-1.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors\"\n          @click=\"openAdd\"\n        >\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 4v16m8-8H4\" />\n          </svg>\n          Ajouter\n        </button>\n      </div>\n    </nav>\n\n    <main class=\"max-w-6xl mx-auto px-4 sm:px-6 py-8\">\n      <!-- Empty state -->\n      <div v-if=\"services.length === 0\" class=\"text-center py-20\">\n        <div class=\"w-16 h-16 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4\">\n          <svg class=\"w-8 h-8 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M5 12h14M12 5l7 7-7 7\" />\n          </svg>\n        </div>\n        <h3 class=\"font-semibold text-gray-900 mb-1\">Aucun service</h3>\n        <p class=\"text-gray-500 text-sm mb-5\">Ajoutez votre premier service à surveiller</p>\n        <button\n          class=\"inline-flex items-center gap-2 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors\"\n          @click=\"openAdd\"\n        >\n          + Ajouter un service\n        </button>\n      </div>\n\n      <!-- List -->\n      <div v-else class=\"space-y-3\">\n        <div\n          v-for=\"svc in services\"\n          :key=\"svc.id\"\n          class=\"bg-white rounded-xl border border-gray-100 shadow-sm p-4 flex items-center gap-4\"\n          :class=\"{ 'opacity-60': !svc.enabled }\"\n        >\n          <!-- Toggle -->\n          <button\n            class=\"shrink-0 relative inline-flex h-5 w-9 items-center rounded-full transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500\"\n            :class=\"svc.enabled ? 'bg-green-500' : 'bg-gray-200'\"\n            :title=\"svc.enabled ? 'Désactiver' : 'Activer'\"\n            @click=\"toggleService(svc.id)\"\n          >\n            <span\n              class=\"inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform\"\n              :class=\"svc.enabled ? 'translate-x-4' : 'translate-x-0.5'\"\n            />\n          </button>\n\n          <!-- Info -->\n          <div class=\"flex-1 min-w-0\">\n            <div class=\"flex items-center gap-2\">\n              <span class=\"font-medium text-gray-900 truncate\">{{ svc.name }}</span>\n              <StatusBadge\n                v-if=\"currentStatus[svc.id]\"\n                :level=\"currentStatus[svc.id].level\"\n                size=\"sm\"\n              />\n              <span\n                v-if=\"svc.group\"\n                class=\"text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500\"\n              >\n                {{ svc.group }}\n              </span>\n            </div>\n            <div class=\"flex items-center gap-3 mt-1 text-xs text-gray-400\">\n              <span class=\"truncate max-w-xs\">{{ svc.url }}</span>\n              <span class=\"shrink-0\">{{ ADAPTER_LABELS[svc.adapter] ?? svc.adapter }}</span>\n              <span class=\"shrink-0\">{{ svc.pollInterval }}s</span>\n            </div>\n          </div>\n\n          <!-- Actions -->\n          <div class=\"flex items-center gap-1 shrink-0\">\n            <button\n              class=\"p-2 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n              title=\"Modifier\"\n              @click=\"openEdit(svc)\"\n            >\n              <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z\" />\n              </svg>\n            </button>\n\n            <button\n              v-if=\"deleteConfirm === svc.id\"\n              class=\"flex items-center gap-1 px-3 py-1.5 rounded-lg bg-red-50 text-red-600 text-xs font-medium hover:bg-red-100 transition-colors\"\n              @click=\"doDelete(svc.id)\"\n            >\n              Confirmer\n            </button>\n            <button\n              v-else\n              class=\"p-2 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors\"\n              title=\"Supprimer\"\n              @click=\"confirmDelete(svc.id)\"\n            >\n              <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- Legend -->\n      <div class=\"mt-8 p-4 rounded-xl bg-white border border-gray-100\">\n        <p class=\"text-xs font-medium text-gray-500 uppercase tracking-wider mb-3\">Légende des niveaux</p>\n        <div class=\"flex flex-wrap gap-3\">\n          <StatusBadge level=\"operational\" size=\"sm\" />\n          <StatusBadge level=\"leger\" size=\"sm\" />\n          <StatusBadge level=\"mineur\" size=\"sm\" />\n          <StatusBadge level=\"majeur\" size=\"sm\" />\n          <StatusBadge level=\"maintenance\" size=\"sm\" />\n        </div>\n      </div>\n    </main>\n\n    <!-- Form modal -->\n    <ServiceForm\n      :open=\"formOpen\"\n      :editing=\"editingService\"\n      @close=\"formOpen = false\"\n      @save=\"onSave\"\n    />\n  </div>\n</template>\n"],"version":3}